# SupplyChain AI — Environment Configuration
# Copy this file to .env and fill in your keys

# Required for live weather data (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key_here

# Optional: OpenRouteService for real routing (https://openrouteservice.org)
# If not set, falls back to Nominatim (OSM) geocoding + haversine distance
ORS_API_KEY=your_ors_key_here

# Optional: OpenAI for natural language explanations
# If not set, uses template-based explanations
OPENAI_API_KEY=your_openai_key_here

# Business configuration (tune as needed)
FUEL_COST_PER_KM=0.12
REROUTE_COST_MULTIPLIER=1.4
MAX_BUDGET_USD=5000
SLA_BREACH_THRESHOLD_HOURS=48
MIN_SUPPLIER_RELIABILITY=0.6
